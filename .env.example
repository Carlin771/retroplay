# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env

# Banco de dados (SQLite). Em desenvolvimento local pode deixar assim.
# No Docker, o docker-compose.yml já sobrescreve para /data/app.db.
DATABASE_URL="file:./prisma/dev.db"

# Chave para assinar as sessões de login. Gere uma aleatória e longa, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="coloque-aqui-uma-chave-aleatoria-bem-grande"

# Primeiro administrador (usado pelo script `npm run create:admin`).
ADMIN_EMAIL="voce@exemplo.com"
ADMIN_PASSWORD="uma-senha-forte"

# --- Telegram ---
# Gere api_id e api_hash em https://my.telegram.org (API development tools).
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
# Gerada por `npm run tg:login`. Mantenha em SEGREDO (dá acesso à sua conta!).
TELEGRAM_SESSION=""

# --- Cache de vídeo ---
CACHE_DIR="./cache"
# Teto do cache em bytes (padrão ~150GB).
CACHE_MAX_BYTES="161061273600"

# --- Deploy ---
# Domínio do site (usado pelo Caddy). Ex.: malhacao.duckdns.org
SITE_DOMAIN="localhost"
